{
	"name": "parcela-mais-challenge",
	"version": "1.0.0",
	"description": "",
	"private": true,
	"license": "MIT",
	"scripts": {
		"prebuild": "rm -rf dist",
		"build": "nest build -p ./tsconfig.build.json -c ./nest-cli.json -b swc",
		"postbuild": "find dist -name '*.spec.js' -o -name '__tests__' | xargs rm -rf",
		"format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
		"prestart": "npm run build",
		"start": "dotenv -e .env.dev -- nest start",
		"start:dev": "npm run start -- --watch",
		"start:prod": "node --env-file=.env ./dist/main",
		"lint": "eslint \"{src,apps,libs,tests}/**/*.ts\"",
		"lint:fix": "npm run lint -- --fix",
		"test:unit": "dotenv -e .env.test -- vitest run --config vitest.config.mts",
		"test:unit:watch": "dotenv -e .env.test -- vitest --config vitest.config.mts",
		"test:e2e": "dotenv -e .env.test -- vitest run --config vitest.e2e.config.mts",
		"test:e2e:watch": "dotenv -e .env.test -- vitest --config vitest.e2e.config.mts",
		"test:cov": "dotenv -e .env.test -- vitest run --config vitest.config.mts --coverage --pool=forks --poolOptions.forks.singleFork=true",
		"db:push:dev": "dotenv -e .env.dev -- prisma db push",
		"db:seed:dev": "dotenv -e .env.dev -- tsx prisma/seed.ts",
		"prepare": "husky install"
	},
	"dependencies": {
		"@nestjs/axios": "^4.0.1",
		"@nestjs/common": "^10.0.0",
		"@nestjs/config": "^3.2.3",
		"@nestjs/core": "^10.0.0",
		"@nestjs/platform-express": "^10.0.0",
		"@nestjs/swagger": "^8.1.0",
		"@prisma/adapter-pg": "7.0.1",
		"@prisma/client": "7.0.1",
		"axios": "^1.13.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"express": "^4.19.2",
		"helmet": "^8.1.0",
		"module-alias": "^2.2.3",
		"nestjs-pino": "^4.5.0",
		"pg": "^8.16.3",
		"pino": "^10.1.0",
		"pino-http": "^11.0.0",
		"reflect-metadata": "^0.2.0",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@faker-js/faker": "^8.4.1",
		"@nestjs/cli": "^10.0.0",
		"@nestjs/schematics": "^10.0.0",
		"@nestjs/testing": "^10.0.0",
		"@swc/cli": "^0.3.14",
		"@swc/core": "^1.7.10",
		"@swc/helpers": "^0.5.8",
		"@testcontainers/postgresql": "^11.12.0",
		"@tsconfig/node-lts": "^20.1.3",
		"@types/express": "^4.17.21",
		"@types/module-alias": "^2.0.4",
		"@types/node": "^20.3.1",
		"@types/passport-jwt": "^4.0.1",
		"@types/pg": "^8.15.6",
		"@types/supertest": "^6.0.3",
		"@typescript-eslint/eslint-plugin": "^8.32.0",
		"@typescript-eslint/parser": "^8.32.0",
		"@vitest/coverage-v8": "3.2.4",
		"dotenv": "^17.2.3",
		"dotenv-cli": "^7.4.2",
		"eslint": "8.57.1",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-import-helpers": "^1.3.1",
		"eslint-plugin-prettier": "^5.0.0",
		"husky": "^8.0.0",
		"lint-staged": "^15.2.11",
		"prettier": "^3.0.0",
		"prisma": "7.0.1",
		"source-map-support": "^0.5.21",
		"supertest": "^7.1.4",
		"testcontainers": "^11.12.0",
		"ts-loader": "^9.4.3",
		"ts-node": "^10.9.1",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.1.3",
		"unplugin-swc": "^1.5.5",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.2.4",
		"vitest-mock-extended": "^4.0.0"
	}
}
