generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model Clinic {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patients              Patient[]
  debtAgreements        DebtAgreement[]
  installments          Installment[]
  payments              Payment[]
  communicationAttempts CommunicationAttempt[]
  paymentWebhookEvents  PaymentWebhookEvent[]

  @@map("clinics")
}

model Patient {
  id               String   @id @default(uuid()) @db.Uuid
  clinicId         String   @map("clinic_id") @db.Uuid
  name             String
  email            String?
  phone            String?
  preferredChannel String?  @map("preferred_channel") // EMAIL, WHATSAPP
  contactStatus    String   @default("ACTIVE") @map("contact_status") //   ACTIVE, DO_NOT_CONTACT, MISSING_CONTACT_INFO
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  clinic                Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  debtAgreements        DebtAgreement[]
  communicationAttempts CommunicationAttempt[]

  @@unique([clinicId, email])
  @@index([clinicId])
  @@index([clinicId, contactStatus])
  @@map("patients")
}

model DebtAgreement {
  id                String   @id @default(uuid()) @db.Uuid
  clinicId          String   @map("clinic_id") @db.Uuid
  patientId         String   @map("patient_id") @db.Uuid
  totalAmountCents  Int      @map("total_amount_cents")
  installmentsCount Int      @map("installments_count")
  status            String   @default("ACTIVE") // ACTIVE, PAID, CANCELED
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  installments Installment[]

  @@index([clinicId])
  @@index([clinicId, status])
  @@index([clinicId, patientId])
  @@map("debt_agreements")
}

model Installment {
  id                String    @id @default(uuid()) @db.Uuid
  clinicId          String    @map("clinic_id") @db.Uuid
  debtAgreementId   String    @map("debt_agreement_id") @db.Uuid
  installmentNumber Int       @map("installment_number")
  dueDate           DateTime  @map("due_date") @db.Date
  amountCents       Int       @map("amount_cents")
  paidAmountCents   Int       @default(0) @map("paid_amount_cents")
  status            String    @default("PENDING") //  PENDING, PARTIALLY_PAID, PAID, CANCELED
  paidAt            DateTime? @map("paid_at")

  // Useful for optimistic concurrency in payment flows
  version Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clinic                Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  debtAgreement         DebtAgreement          @relation(fields: [debtAgreementId], references: [id], onDelete: Restrict)
  payments              Payment[]
  communicationAttempts CommunicationAttempt[]
  paymentWebhookEvents  PaymentWebhookEvent[]

  @@unique([debtAgreementId, installmentNumber])
  @@index([clinicId])
  @@index([clinicId, status])
  @@index([clinicId, dueDate])
  @@index([clinicId, status, dueDate])
  @@map("installments")
}

model Payment {
  id                String  @id @default(uuid()) @db.Uuid
  clinicId          String  @map("clinic_id") @db.Uuid
  installmentId     String  @map("installment_id") @db.Uuid
  amountCents       Int     @map("amount_cents")
  method            String //   PIX, BOLETO, MANUAL, WEBHOOK_SIMULATED
  externalReference String? @map("external_reference")
  idempotencyKey    String  @map("idempotency_key")

  // Store a normalized hash of the relevant request payload to detect
  // same idempotency key with different amount/method/installment/paidAt
  idempotencyPayloadHash String @map("idempotency_payload_hash")

  paidAt    DateTime @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  clinic               Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  installment          Installment           @relation(fields: [installmentId], references: [id], onDelete: Restrict)
  paymentWebhookEvents PaymentWebhookEvent[]

  @@unique([clinicId, idempotencyKey])
  @@unique([clinicId, externalReference])
  @@index([clinicId])
  @@index([clinicId, installmentId])
  @@index([clinicId, paidAt])
  @@map("payments")
}

model CommunicationAttempt {
  id            String    @id @default(uuid()) @db.Uuid
  clinicId      String    @map("clinic_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  installmentId String    @map("installment_id") @db.Uuid
  type          String // PRE_DUE_REMINDER, DUE_DATE_REMINDER, OVERDUE_SOFT_NOTICE, OVERDUE_FOLLOW_UP, OVERDUE_ESCALATION, PAYMENT_CONFIRMATION
  channel       String //  WHATSAPP, EMAIL
  status        String    @default("GENERATED") //  PENDING, GENERATED, SENT_SIMULATED, SKIPPED, FAILED
  scheduledFor  DateTime? @map("scheduled_for")
  sentAt        DateTime? @map("sent_at")
  skippedReason String?   @map("skipped_reason")
  message       String?   @db.Text
  aiGenerated   Boolean   @default(false) @map("ai_generated")
  templateKey   String?   @map("template_key")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  installment Installment @relation(fields: [installmentId], references: [id], onDelete: Restrict)

  // Deduplication key for the collection rule:
  // clinicId + patientId + installmentId + communicationType + channel
  @@unique([clinicId, patientId, installmentId, type, channel])
  @@index([clinicId])
  @@index([clinicId, status])
  @@index([clinicId, scheduledFor])
  @@index([clinicId, patientId, createdAt])
  @@map("communication_attempts")
}

model PaymentWebhookEvent {
  id                String    @id @default(uuid()) @db.Uuid
  clinicId          String    @map("clinic_id") @db.Uuid
  installmentId     String?   @map("installment_id") @db.Uuid
  paymentId         String?   @map("payment_id") @db.Uuid
  provider          String
  eventId           String    @map("event_id")
  externalReference String?   @map("external_reference")
  payload           Json
  payloadHash       String    @map("payload_hash")
  status            String    @default("RECEIVED") // RECEIVED, PROCESSED, DUPLICATED, FAILED
  processedAt       DateTime? @map("processed_at")
  errorCode         String?   @map("error_code")
  retryable         Boolean?  @map("retryable")
  errorMessage      String?   @map("error_message") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  installment Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  payment     Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  // Provider event ids should be idempotent globally for simulated webhooks.
  @@unique([provider, eventId])
  @@index([clinicId])
  @@index([clinicId, status])
  @@index([clinicId, externalReference])
  @@map("payment_webhook_events")
}
